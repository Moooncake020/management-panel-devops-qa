@model List<GorevAktiviteListeItemViewModel>

<section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="mb-5">
        <div class="flex items-center gap-2">
            <svg class="h-5 w-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h2 class="text-lg font-extrabold text-slate-800">Aktivite geçmişi</h2>
        </div>
        <p class="mt-1 text-sm text-slate-500">Görev üzerindeki önemli değişikliklerin zaman çizelgesi.</p>
    </div>

    @if (!Model.Any())
    {
        <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 px-4 py-8 text-center text-sm text-slate-400">
            Bu görev için henüz aktivite kaydı bulunmuyor.
        </div>
    }
    else
    {
        <ol class="relative ml-3 border-l border-slate-200">
            @foreach (var aktivite in Model)
            {
                var ikonSinifi = "bg-slate-100 text-slate-500";
                var ikonYolu = "M12 8v4l3 3";

                switch (aktivite.IslemTuru)
                {
                    case GorevAktiviteTurleri.Olusturuldu:
                        ikonSinifi = "bg-teal-50 text-teal-600";
                        ikonYolu = "M12 4v16m8-8H4";
                        break;
                    case GorevAktiviteTurleri.DurumDegisti:
                        ikonSinifi = "bg-purple-50 text-purple-600";
                        ikonYolu = "M4 6h16M4 12h10M4 18h7";
                        break;
                    case GorevAktiviteTurleri.AtananDegisti:
                    case GorevAktiviteTurleri.GorevDevredildi:
                        ikonSinifi = "bg-amber-50 text-amber-600";
                        ikonYolu = "M8 7h12m0 0l-4-4m4 4l-4 4M16 17H4m0 0l4 4m-4-4l4-4";
                        break;
                    case GorevAktiviteTurleri.IcerikGuncellendi:
                        ikonSinifi = "bg-blue-50 text-blue-600";
                        ikonYolu = "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z";
                        break;
                    case GorevAktiviteTurleri.GorselGuncellendi:
                        ikonSinifi = "bg-indigo-50 text-indigo-600";
                        ikonYolu = "M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14M4 8h16";
                        break;
                    case GorevAktiviteTurleri.OncelikDegisti:
                        ikonSinifi = "bg-red-50 text-red-600";
                        ikonYolu = "M12 9v2m0 4h.01M5.07 19h13.86a2 2 0 001.74-3L13.74 4a2 2 0 00-3.48 0L3.33 16A2 2 0 005.07 19z";
                        break;
                    case GorevAktiviteTurleri.TarihPlaniDegisti:
                        ikonSinifi = "bg-cyan-50 text-cyan-600";
                        ikonYolu = "M8 7V3m8 4V3M5 11h14M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z";
                        break;
                    case GorevAktiviteTurleri.YorumEklendi:
                    case GorevAktiviteTurleri.YorumSilindi:
                        ikonSinifi = "bg-emerald-50 text-emerald-600";
                        ikonYolu = "M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.87 9.87 0 01-4-.8L3 20l1.3-3.1A7.22 7.22 0 013 12c0-4.418 4.03-8 9-8s9 3.582 9 8z";
                        break;
                }

                <li class="relative mb-6 ml-7 last:mb-0">
                    <span class="absolute -left-[2.55rem] top-0 flex h-8 w-8 items-center justify-center rounded-xl ring-4 ring-white @ikonSinifi">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@ikonYolu" />
                        </svg>
                    </span>

                    <div class="rounded-2xl bg-slate-50 p-3">
                        <p class="text-sm font-semibold leading-5 text-slate-700">@aktivite.Aciklama</p>
                        <div class="mt-2 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-slate-400">
                            <span class="font-semibold text-slate-500">@aktivite.KullaniciAdi</span>
                            <span aria-hidden="true">•</span>
                            <time datetime="@aktivite.OlusturulmaTarihi.ToString("O")">
                                @aktivite.OlusturulmaTarihi.ToString("dd MMM yyyy · HH:mm")
                            </time>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(aktivite.EskiDeger) ||
                             !string.IsNullOrWhiteSpace(aktivite.YeniDeger))
                        {
                            <div class="mt-3 grid grid-cols-1 gap-2 text-xs sm:grid-cols-2 xl:grid-cols-1">
                                @if (!string.IsNullOrWhiteSpace(aktivite.EskiDeger))
                                {
                                    <div class="rounded-xl border border-red-100 bg-red-50 px-3 py-2 text-red-700">
                                        <div class="mb-1 font-bold uppercase tracking-wider text-red-400">Önce</div>
                                        <div class="break-words">@aktivite.EskiDeger</div>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(aktivite.YeniDeger))
                                {
                                    <div class="rounded-xl border border-emerald-100 bg-emerald-50 px-3 py-2 text-emerald-700">
                                        <div class="mb-1 font-bold uppercase tracking-wider text-emerald-400">Sonra</div>
                                        <div class="break-words">@aktivite.YeniDeger</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </li>
            }
        </ol>
    }
</section>
