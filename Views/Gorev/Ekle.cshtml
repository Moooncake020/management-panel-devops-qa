@model GorevEkleViewModel

@{
    ViewData["Title"] = "Yeni Görev";
}

<div class="mx-auto w-full max-w-5xl space-y-6">
    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm lg:p-7">
        <a asp-controller="Gorev"
           asp-action="Index"
           class="inline-flex items-center gap-2 text-sm font-bold text-teal-600 transition hover:text-teal-700">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Görev listesine dön
        </a>

        <div class="mt-5 flex items-start gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-teal-50 text-teal-600">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
            </div>
            <div>
                <div class="text-xs font-bold uppercase tracking-[0.2em] text-teal-600">Görev oluşturma</div>
                <h1 class="mt-1 text-2xl font-extrabold tracking-tight text-slate-800 lg:text-3xl">Yeni görev ekle</h1>
                <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-500">
                    Görevin içeriğini yazın ve yetkiniz kapsamında görev verebileceğiniz kullanıcıyı seçin.
                    Yeni görev, kontrollü iş akışı gereği <strong class="font-bold text-slate-700">Açık</strong> durumunda oluşturulur.
                </p>
            </div>
        </div>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm lg:p-7">
        <form id="createTaskForm"
              data-task-form="create"
              asp-action="Ekle"
              method="post"
              enctype="multipart/form-data"
              novalidate
              class="space-y-6">

            <div asp-validation-summary="ModelOnly"
                 class="validation-summary-errors rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-semibold text-red-700"
                 role="alert">
            </div>

            <div class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1fr)_300px]">
                <div class="space-y-6">
                    <div>
                        <div class="mb-2 flex items-center justify-between gap-3">
                            <label asp-for="Baslik" class="text-sm font-bold text-slate-700"></label>
                            <span id="titleCounter" class="text-xs font-semibold text-slate-400">0 / 120</span>
                        </div>
                        <input asp-for="Baslik"
                               maxlength="120"
                               autocomplete="off"
                               placeholder="Örneğin: Kullanıcı raporu ekranını hazırla"
                               class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-700 transition focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500" />
                        <span asp-validation-for="Baslik" class="mt-1.5 block text-sm font-semibold text-red-600"></span>
                        <p class="mt-1.5 text-xs leading-5 text-slate-400">Görevi tek bakışta anlatan kısa ve açık bir başlık yazın.</p>
                    </div>

                    <div>
                        <div class="mb-2 flex items-center justify-between gap-3">
                            <label asp-for="Aciklama" class="text-sm font-bold text-slate-700"></label>
                            <span id="descriptionCounter" class="text-xs font-semibold text-slate-400">0 / 2000</span>
                        </div>
                        <textarea asp-for="Aciklama"
                                  rows="8"
                                  maxlength="2000"
                                  placeholder="Beklenen sonucu, önemli detayları ve varsa kabul kriterlerini yazın..."
                                  class="min-h-[190px] w-full resize-y rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-700 transition focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500"></textarea>
                        <span asp-validation-for="Aciklama" class="mt-1.5 block text-sm font-semibold text-red-600"></span>
                    </div>

                    <div>
                        <label asp-for="AtananKullaniciId" class="mb-2 block text-sm font-bold text-slate-700"></label>
                        <select asp-for="AtananKullaniciId"
                                class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-700 transition focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500">
                            <option value="">Bir kullanıcı seçin...</option>
                            @foreach (var kullanici in Model.Kullanicilar)
                            {
                                <option value="@kullanici.Id">@kullanici.TamAd</option>
                            }
                        </select>
                        <span asp-validation-for="AtananKullaniciId" class="mt-1.5 block text-sm font-semibold text-red-600"></span>
                        <p class="mt-1.5 text-xs leading-5 text-slate-400">Listede yalnızca organizasyon yetkiniz kapsamında görev verebileceğiniz aktif kullanıcılar görünür.</p>
                    </div>

                    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 lg:p-5">
                        <div class="mb-4 flex items-center gap-2">
                            <svg class="h-5 w-5 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3M5 11h14M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                            <div>
                                <h2 class="text-sm font-extrabold text-slate-800">Planlama bilgileri</h2>
                                <p class="text-xs leading-5 text-slate-500">Öncelik ve tarihler görev sıralamasını, gecikme uyarılarını ve dashboard metriklerini besler.</p>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                            <div>
                                <label asp-for="Oncelik" class="mb-2 block text-sm font-bold text-slate-700"></label>
                                <select asp-for="Oncelik"
                                        class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-slate-700 focus:outline-none focus:ring-2 focus:ring-teal-500">
                                    @foreach (var oncelik in Enum.GetValues<GorevOnceligi>())
                                    {
                                        var oncelikMetni = oncelik switch
                                        {
                                            GorevOnceligi.Dusuk => "Düşük",
                                            GorevOnceligi.Normal => "Normal",
                                            GorevOnceligi.Yuksek => "Yüksek",
                                            GorevOnceligi.Kritik => "Kritik",
                                            _ => oncelik.ToString()
                                        };
                                        <option value="@((int)oncelik)">@oncelikMetni</option>
                                    }
                                </select>
                                <span asp-validation-for="Oncelik" class="mt-1.5 block text-sm font-semibold text-red-600"></span>
                            </div>

                            <div>
                                <label asp-for="BaslangicTarihi" class="mb-2 block text-sm font-bold text-slate-700"></label>
                                <input asp-for="BaslangicTarihi"
                                       type="date"
                                       asp-format="{0:yyyy-MM-dd}"
                                       class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-slate-700 focus:outline-none focus:ring-2 focus:ring-teal-500" />
                                <span asp-validation-for="BaslangicTarihi" class="mt-1.5 block text-sm font-semibold text-red-600"></span>
                            </div>

                            <div>
                                <label asp-for="SonTarih" class="mb-2 block text-sm font-bold text-slate-700"></label>
                                <input asp-for="SonTarih"
                                       type="date"
                                       asp-format="{0:yyyy-MM-dd}"
                                       class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-slate-700 focus:outline-none focus:ring-2 focus:ring-teal-500" />
                                <span asp-validation-for="SonTarih" class="mt-1.5 block text-sm font-semibold text-red-600"></span>
                            </div>
                        </div>
                        <div id="datePlanWarning" class="mt-3 hidden rounded-xl border border-red-200 bg-red-50 px-3 py-2 text-sm font-semibold text-red-700" role="alert">
                            Son tarih, başlangıç tarihinden önce olamaz.
                        </div>
                    </div>
                </div>

                <aside class="space-y-4">
                    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                        <div class="flex items-center gap-3">
                            <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-white text-slate-500 shadow-sm">
                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <div>
                                <div class="text-xs font-bold uppercase tracking-wider text-slate-400">Başlangıç durumu</div>
                                <div class="mt-1 font-bold text-slate-800">Açık</div>
                            </div>
                        </div>
                        <p class="mt-3 text-xs leading-5 text-slate-500">Görev oluşturulduktan sonra durum, izin verilen akış adımlarıyla ilerletilir.</p>
                    </div>

                    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                        <label asp-for="ResimDosyasi" class="mb-2 block text-sm font-bold text-slate-700"></label>
                        <label for="ResimDosyasi"
                               class="flex cursor-pointer flex-col items-center justify-center rounded-2xl border-2 border-dashed border-slate-200 bg-slate-50 px-4 py-7 text-center transition hover:border-teal-300 hover:bg-teal-50/40">
                            <svg class="h-8 w-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14M4 8h16" />
                            </svg>
                            <span class="mt-2 text-sm font-bold text-slate-700">Görsel seç</span>
                            <span class="mt-1 text-xs leading-5 text-slate-400">JPG, PNG veya WEBP · En fazla 5 MB</span>
                        </label>
                        <input asp-for="ResimDosyasi"
                               type="file"
                               accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp"
                               class="sr-only" />
                        <span asp-validation-for="ResimDosyasi" class="mt-2 block text-sm font-semibold text-red-600"></span>

                        <div id="selectedFileInfo" class="mt-3 hidden rounded-2xl bg-slate-50 p-3 text-xs text-slate-600"></div>

                        <img id="imagePreview"
                             alt="Seçilen görev görselinin ön izlemesi"
                             class="mt-3 hidden max-h-48 w-full rounded-2xl border border-slate-200 object-contain" />
                    </div>
                </aside>
            </div>

            <div data-task-submit-bar class="sticky bottom-3 z-20 flex flex-col gap-3 rounded-2xl border border-slate-200 bg-white/95 p-3 shadow-lg backdrop-blur sm:flex-row sm:items-center sm:justify-between">
                <div id="taskDirtyIndicator" class="hidden text-sm font-semibold text-amber-700">
                    Kaydedilmemiş değişiklikler var
                </div>
                <div class="flex flex-col-reverse gap-3 sm:ml-auto sm:flex-row">
                <a asp-controller="Gorev"
                   asp-action="Index"
                   class="inline-flex items-center justify-center gap-2 rounded-2xl bg-slate-100 px-5 py-3 text-sm font-bold text-slate-600 transition hover:bg-slate-200">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                    İptal
                </a>

                <button id="createTaskButton"
                        data-task-submit
                        type="submit"
                        class="inline-flex items-center justify-center gap-2 rounded-2xl bg-gradient-to-r from-teal-500 to-teal-600 px-6 py-3 text-sm font-bold text-white shadow-sm transition hover:from-teal-600 hover:to-teal-700 hover:shadow-md disabled:opacity-60">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span data-button-text>Görev Oluştur</span>
                </button>
                </div>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/gorev-form.js" asp-append-version="true" defer></script>
}
