@model GorevIndexViewModel

<div id="taskCardsContainer" class="task-card-view grid grid-cols-1 gap-4 lg:grid-cols-2 2xl:grid-cols-3">
    @foreach (var item in Model.Gorevler)
    {
        var atananKullaniciDegeri = item.AtananKullaniciId?.ToString() ?? "none";
        var aramaMetni = $"{item.Baslik} {item.Aciklama} {item.AtananKisi} {item.GoreviVeren} {item.Durum} {item.OncelikMetni} {item.KalanGunMetni}";

        <article class="task-item flex min-w-0 flex-col overflow-hidden rounded-2xl border bg-white shadow-xs transition hover:-translate-y-0.5 hover:shadow-md @(item.GeciktiMi ? "border-red-200 ring-1 ring-red-100" : "border-slate-200 hover:border-slate-300")"
                 data-task-id="@item.Id"
                 data-search="@aramaMetni"
                 data-status="@item.DurumKodu"
                 data-priority="@item.OncelikKodu"
                 data-date-status="@item.TarihDurumKodu"
                 data-due="@(item.SonTarih?.ToString("O") ?? string.Empty)"
                 data-scopes="@item.KapsamKodlari"
                 data-assignee="@atananKullaniciDegeri"
                 data-created="@item.OlusturulmaTarihi.ToString("O")"
                 data-title="@item.Baslik">

            @if (!string.IsNullOrWhiteSpace(item.ResimYolu))
            {
                <button type="button"
                        class="task-image-trigger group relative block h-44 w-full overflow-hidden bg-slate-100 text-left"
                        data-image-src="@item.ResimYolu"
                        data-image-alt="@item.Baslik görev görseli"
                        aria-label="@item.Baslik görev görselini büyüt">
                    <img src="@item.ResimYolu"
                         alt="@item.Baslik görev görseli"
                         width="720"
                         height="400"
                         loading="lazy"
                         decoding="async"
                         class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]" />
                    <span class="absolute bottom-3 right-3 inline-flex h-9 w-9 items-center justify-center rounded-xl bg-slate-950/70 text-white backdrop-blur">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 3h6m0 0v6m0-6l-7 7M9 21H3m0 0v-6m0 6l7-7" />
                        </svg>
                    </span>
                </button>
            }

            <div class="flex flex-1 flex-col p-4 sm:p-5">
                <div class="mb-4 flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <div class="flex flex-wrap items-center gap-2">
                            <partial name="_GorevDurumRozeti" model="item.Durum" />
                            <partial name="_GorevOncelikRozeti" model="item.Oncelik" />
                        </div>
                        <h3 class="mt-3 line-clamp-2 text-lg font-extrabold leading-6 text-slate-800" title="@item.Baslik">
                            <a asp-controller="Gorev"
                               asp-action="Detay"
                               asp-route-id="@item.Id"
                               class="transition hover:text-teal-700">
                                @item.Baslik
                            </a>
                        </h3>
                    </div>

                    @if (item.SilebilirMi)
                    {
                        <details class="action-menu shrink-0">
                            <summary class="inline-flex h-10 w-10 cursor-pointer items-center justify-center rounded-xl border border-slate-200 bg-slate-50 text-slate-500 transition hover:bg-slate-100 hover:text-slate-800"
                                     aria-label="Görev işlemleri">
                                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <circle cx="5" cy="12" r="1.8" />
                                    <circle cx="12" cy="12" r="1.8" />
                                    <circle cx="19" cy="12" r="1.8" />
                                </svg>
                            </summary>
                            <div class="action-menu__panel p-2">
                                <form asp-controller="Gorev"
                                      asp-action="Sil"
                                      asp-route-id="@item.Id"
                                      method="post"
                                      data-confirm="Bu görevi silmek istediğinize emin misiniz?" data-confirm-title="Görevi sil" data-confirm-action="Görevi sil" data-confirm-tone="danger">
                                    <button type="submit" class="flex w-full items-center gap-2 rounded-xl px-3 py-2.5 text-left text-sm font-semibold text-red-600 transition hover:bg-red-50">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3" />
                                        </svg>
                                        Görevi sil
                                    </button>
                                </form>
                            </div>
                        </details>
                    }
                </div>

                <p class="mb-5 line-clamp-3 text-sm leading-6 text-slate-500">
                    @(string.IsNullOrWhiteSpace(item.Aciklama) ? "Bu görev için açıklama girilmemiş." : item.Aciklama)
                </p>

                <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                    <div class="rounded-xl border border-slate-100 bg-slate-50 p-3">
                        <div class="mb-1 flex items-center gap-1.5 text-xs font-bold uppercase tracking-wider text-slate-400">
                            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A7 7 0 0112 15a7 7 0 016.879 2.804M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                            Atanan kişi
                        </div>
                        @if (item.AtananKullaniciId.HasValue)
                        {
                            <a asp-controller="Profil" asp-action="Index" asp-route-id="@item.AtananKullaniciId" class="block truncate font-semibold text-slate-700 transition hover:text-teal-700" title="@item.AtananKisi">@item.AtananKisi</a>
                        }
                        else
                        {
                            <div class="truncate font-semibold text-slate-700" title="@item.AtananKisi">@item.AtananKisi</div>
                        }
                    </div>

                    <div class="rounded-xl border border-slate-100 bg-slate-50 p-3">
                        <div class="mb-1 flex items-center gap-1.5 text-xs font-bold uppercase tracking-wider text-slate-400">
                            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            Oluşturan
                        </div>
                        @if (item.OlusturanKullaniciId.HasValue)
                        {
                            <a asp-controller="Profil" asp-action="Index" asp-route-id="@item.OlusturanKullaniciId" class="block truncate font-semibold text-slate-700 transition hover:text-teal-700" title="@item.GoreviVeren">@item.GoreviVeren</a>
                        }
                        else
                        {
                            <div class="truncate font-semibold text-slate-700" title="@item.GoreviVeren">@item.GoreviVeren</div>
                        }
                    </div>
                </div>

                <div class="mt-3 rounded-2xl border px-3 py-2.5 @(item.GeciktiMi ? "border-red-100 bg-red-50" : item.BugunBitiyorMu ? "border-amber-100 bg-amber-50" : "border-slate-100 bg-slate-50")">
                    <div class="flex flex-wrap items-center justify-between gap-2">
                        <div>
                            <div class="text-xs font-bold uppercase tracking-wider text-slate-400">Son tarih</div>
                            <div class="mt-0.5 text-sm font-bold @(item.GeciktiMi ? "text-red-700" : item.BugunBitiyorMu ? "text-amber-700" : "text-slate-700")">
                                @(item.SonTarih?.ToString("dd MMM yyyy") ?? "Belirtilmedi")
                            </div>
                        </div>
                        <span class="rounded-full px-2.5 py-1 text-xs font-bold @(item.GeciktiMi ? "bg-red-100 text-red-700" : item.BugunBitiyorMu ? "bg-amber-100 text-amber-700" : item.YaklasanMi ? "bg-cyan-100 text-cyan-700" : "bg-white text-slate-500")">
                            @item.KalanGunMetni
                        </span>
                    </div>
                </div>

                <div class="mt-5 flex flex-col gap-3 border-t border-slate-100 pt-4 sm:flex-row sm:items-center sm:justify-between">
                    <div class="flex flex-wrap items-center gap-3 text-xs font-semibold text-slate-400">
                        <span class="inline-flex items-center gap-2">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3M5 11h14M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                            @item.OlusturulmaTarihi.ToString("dd MMM yyyy")
                        </span>

                        <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-2.5 py-1 text-slate-500">
                            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.87 9.87 0 01-4-.8L3 20l1.3-3.1A7.22 7.22 0 013 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                            </svg>
                            @item.YorumSayisi yorum
                        </span>
                    </div>

                    <div class="grid grid-cols-2 gap-2 sm:flex">
                        <a asp-controller="Gorev"
                           asp-action="Detay"
                           asp-route-id="@item.Id"
                           class="inline-flex items-center justify-center gap-2 rounded-xl bg-teal-50 px-4 py-2.5 text-sm font-bold text-teal-700 transition hover:bg-teal-600 hover:text-white">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zm6 0c-1.5 4-4.5 6-9 6s-7.5-2-9-6c1.5-4 4.5-6 9-6s7.5 2 9 6z" />
                            </svg>
                            Detay
                        </a>

                        <a asp-controller="Gorev"
                           asp-action="Duzenle"
                           asp-route-id="@item.Id"
                           class="inline-flex items-center justify-center gap-2 rounded-xl bg-blue-50 px-4 py-2.5 text-sm font-bold text-blue-600 transition hover:bg-blue-600 hover:text-white">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
                            </svg>
                            Düzenle
                        </a>
                    </div>
                </div>
            </div>
        </article>
    }
</div>
