@model GorevIndexViewModel

<div class="task-table-view">
    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white">
        <div class="soft-scroll overflow-x-auto">
            <table class="w-full min-w-[1240px] border-collapse text-left text-sm">
                <caption class="sr-only">Filtrelenmiş görev listesi</caption>
                <thead>
                    <tr class="border-b border-slate-200 bg-slate-50 text-xs font-bold uppercase tracking-wider text-slate-500">
                        <th scope="col" class="w-[370px] p-4">Görev</th>
                        <th scope="col" class="w-[200px] p-4">Atanan kişi</th>
                        <th scope="col" class="w-[190px] p-4">Görevi veren</th>
                        <th scope="col" class="w-[170px] p-4">Durum</th>
                        <th scope="col" class="w-[120px] p-4">Öncelik</th>
                        <th scope="col" class="w-[170px] p-4">Son tarih</th>
                        <th scope="col" class="w-[120px] p-4">Oluşturma</th>
                        <th scope="col" class="w-[220px] p-4 text-right">İşlemler</th>
                    </tr>
                </thead>
                <tbody id="tasksTableBody">
                    @foreach (var item in Model.Gorevler)
                    {
                        var atananKullaniciDegeri = item.AtananKullaniciId?.ToString() ?? "none";
                        var aramaMetni = $"{item.Baslik} {item.Aciklama} {item.AtananKisi} {item.GoreviVeren} {item.Durum} {item.OncelikMetni} {item.KalanGunMetni}";

                        <tr class="task-item group border-b align-middle last:border-0 hover:bg-slate-50 @(item.GeciktiMi ? "border-red-100 bg-red-50/30" : "border-slate-200")"
                            data-task-id="@item.Id"
                            data-search="@aramaMetni"
                            data-status="@item.DurumKodu"
                            data-priority="@item.OncelikKodu"
                            data-date-status="@item.TarihDurumKodu"
                            data-due="@(item.SonTarih?.ToString("O") ?? string.Empty)"
                            data-scopes="@item.KapsamKodlari"
                            data-assignee="@atananKullaniciDegeri"
                            data-created="@item.OlusturulmaTarihi.ToString("O")"
                            data-title="@item.Baslik">

                            <td class="p-4">
                                <div class="flex min-w-0 items-center gap-3">
                                    @if (!string.IsNullOrWhiteSpace(item.ResimYolu))
                                    {
                                        <button type="button"
                                                class="task-image-trigger h-14 w-14 shrink-0 overflow-hidden rounded-2xl border border-slate-200 bg-slate-100"
                                                data-image-src="@item.ResimYolu"
                                                data-image-alt="@item.Baslik görev görseli"
                                                aria-label="@item.Baslik görev görselini büyüt">
                                            <img src="@item.ResimYolu" alt="" width="64" height="64" loading="lazy" decoding="async" class="h-full w-full object-cover transition group-hover:scale-105" />
                                        </button>
                                    }
                                    else
                                    {
                                        <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl border border-slate-200 bg-slate-50 text-slate-300">
                                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14M4 8h16" />
                                            </svg>
                                        </div>
                                    }

                                    <div class="min-w-0">
                                        <div class="truncate text-base font-bold text-slate-800" title="@item.Baslik">
                                            <a asp-controller="Gorev"
                                               asp-action="Detay"
                                               asp-route-id="@item.Id"
                                               class="transition hover:text-teal-700">
                                                @item.Baslik
                                            </a>
                                        </div>
                                        <div class="mt-1 line-clamp-2 max-w-[285px] text-xs leading-5 text-slate-500">
                                            @(string.IsNullOrWhiteSpace(item.Aciklama) ? "Açıklama girilmemiş." : item.Aciklama)
                                        </div>
                                    </div>
                                </div>
                            </td>

                            <td class="p-4">
                                @if (item.AtananKullaniciId.HasValue)
                                {
                                    <a asp-controller="Profil" asp-action="Index" asp-route-id="@item.AtananKullaniciId" class="block truncate font-semibold text-slate-700 transition hover:text-teal-700" title="@item.AtananKisi">@item.AtananKisi</a>
                                }
                                else
                                {
                                    <div class="truncate font-semibold text-slate-700" title="@item.AtananKisi">@item.AtananKisi</div>
                                }
                            </td>

                            <td class="p-4">
                                @if (item.OlusturanKullaniciId.HasValue)
                                {
                                    <a asp-controller="Profil" asp-action="Index" asp-route-id="@item.OlusturanKullaniciId" class="block truncate text-slate-600 transition hover:text-teal-700" title="@item.GoreviVeren">@item.GoreviVeren</a>
                                }
                                else
                                {
                                    <div class="truncate text-slate-600" title="@item.GoreviVeren">@item.GoreviVeren</div>
                                }
                            </td>

                            <td class="p-4">
                                <partial name="_GorevDurumRozeti" model="item.Durum" />
                            </td>

                            <td class="p-4">
                                <partial name="_GorevOncelikRozeti" model="item.Oncelik" />
                            </td>

                            <td class="p-4">
                                <div class="font-bold @(item.GeciktiMi ? "text-red-700" : item.BugunBitiyorMu ? "text-amber-700" : "text-slate-700")">
                                    @(item.SonTarih?.ToString("dd.MM.yyyy") ?? "Belirtilmedi")
                                </div>
                                <div class="mt-1 text-xs font-semibold @(item.GeciktiMi ? "text-red-500" : item.BugunBitiyorMu ? "text-amber-500" : "text-slate-400")">
                                    @item.KalanGunMetni
                                </div>
                            </td>

                            <td class="p-4 text-sm font-medium text-slate-500">
                                <div>@item.OlusturulmaTarihi.ToString("dd.MM.yyyy")</div>
                                <div class="mt-1 inline-flex items-center gap-1 text-xs font-semibold text-slate-400">
                                    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.87 9.87 0 01-4-.8L3 20l1.3-3.1A7.22 7.22 0 013 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                                    </svg>
                                    @item.YorumSayisi yorum
                                </div>
                            </td>

                            <td class="p-4">
                                <div class="flex items-center justify-end gap-2">
                                    <a asp-controller="Gorev"
                                       asp-action="Detay"
                                       asp-route-id="@item.Id"
                                       class="inline-flex items-center justify-center gap-1.5 rounded-xl bg-teal-50 px-3 py-2 text-[12px] font-bold text-teal-700 transition hover:bg-teal-600 hover:text-white">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zm6 0c-1.5 4-4.5 6-9 6s-7.5-2-9-6c1.5-4 4.5-6 9-6s7.5 2 9 6z" />
                                        </svg>
                                        Detay
                                    </a>

                                    <a asp-controller="Gorev"
                                       asp-action="Duzenle"
                                       asp-route-id="@item.Id"
                                       class="inline-flex items-center justify-center gap-1.5 rounded-xl bg-blue-50 px-3 py-2 text-[12px] font-bold text-blue-600 transition hover:bg-blue-600 hover:text-white">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
                                        </svg>
                                        Düzenle
                                    </a>

                                    @if (item.SilebilirMi)
                                    {
                                        <details class="action-menu">
                                            <summary class="inline-flex h-9 w-9 cursor-pointer items-center justify-center rounded-xl border border-slate-200 bg-slate-50 text-slate-500 transition hover:bg-slate-100 hover:text-slate-800"
                                                     aria-label="Görev işlemleri">
                                                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                                    <circle cx="5" cy="12" r="1.8" />
                                                    <circle cx="12" cy="12" r="1.8" />
                                                    <circle cx="19" cy="12" r="1.8" />
                                                </svg>
                                            </summary>
                                            <div class="action-menu__panel p-2">
                                                <form asp-controller="Gorev"
                                                      asp-action="Sil"
                                                      asp-route-id="@item.Id"
                                                      method="post"
                                                      data-confirm="Bu görevi silmek istediğinize emin misiniz?" data-confirm-title="Görevi sil" data-confirm-action="Görevi sil" data-confirm-tone="danger">
                                                    <button type="submit" class="flex w-full items-center gap-2 rounded-xl px-3 py-2.5 text-left text-sm font-semibold text-red-600 transition hover:bg-red-50">
                                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3" />
                                                        </svg>
                                                        Görevi sil
                                                    </button>
                                                </form>
                                            </div>
                                        </details>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
