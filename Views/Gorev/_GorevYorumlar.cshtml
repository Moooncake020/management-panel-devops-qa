@model GorevDetayViewModel

<section id="yorumlar" class="scroll-mt-24 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm lg:p-6">
    <div class="mb-5 flex items-center justify-between gap-3">
        <div>
            <div class="flex items-center gap-2">
                <svg class="h-5 w-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.87 9.87 0 01-4-.8L3 20l1.3-3.1A7.22 7.22 0 013 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
                <h2 class="text-lg font-extrabold text-slate-800">Yorumlar</h2>
                <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-bold text-slate-500">@Model.Yorumlar.Count</span>
            </div>
            <p class="mt-1 text-sm text-slate-500">Görevle ilgili notları ve güncellemeleri ekip içinde paylaşın.</p>
        </div>
    </div>

    @if (Model.YorumYazabilirMi)
    {
        <form asp-controller="Gorev"
              asp-action="YorumEkle"
              method="post"
              id="commentForm"
              class="mb-6 rounded-2xl border border-slate-200 bg-slate-50 p-4">
            <input type="hidden" name="GorevId" value="@Model.Id" />

            <div class="mb-2 flex items-center justify-between gap-3">
                <label for="commentContent" class="text-sm font-bold text-slate-700">Yeni yorum</label>
                <span id="commentCounter" class="text-xs font-semibold text-slate-400">0 / 2000</span>
            </div>

            <textarea id="commentContent"
                      name="Icerik"
                      rows="4"
                      minlength="2"
                      maxlength="2000"
                      required
                      placeholder="Görevle ilgili bir not yazın..."
                      class="min-h-[110px] w-full resize-y rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm leading-6 text-slate-700 transition focus:outline-none focus:ring-2 focus:ring-teal-500">@Model.YeniYorum.Icerik</textarea>

            @Html.ValidationMessage(
                "Icerik",
                null,
                new { @class = "mt-1.5 block text-sm font-semibold text-red-600" }
            )

            <div class="mt-3 flex justify-end">
                <button type="submit"
                        id="commentSubmitButton"
                        class="inline-flex items-center justify-center gap-2 rounded-2xl bg-teal-600 px-5 py-2.5 text-sm font-bold text-white transition hover:bg-teal-700 disabled:cursor-not-allowed disabled:opacity-60">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                    </svg>
                    <span data-button-text>Yorum Ekle</span>
                </button>
            </div>
        </form>
    }

    @if (!Model.Yorumlar.Any())
    {
        <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 px-5 py-10 text-center">
            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-2xl bg-white text-slate-300 shadow-sm">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.87 9.87 0 01-4-.8L3 20l1.3-3.1A7.22 7.22 0 013 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
            </div>
            <div class="mt-3 font-bold text-slate-600">Henüz yorum yok</div>
            <p class="mt-1 text-sm text-slate-400">İlk yorumu ekleyerek ekip iletişimini başlatabilirsiniz.</p>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var yorum in Model.Yorumlar)
            {
                <article class="rounded-2xl border border-slate-200 bg-white p-4">
                    <div class="flex items-start gap-3">
                        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-teal-50 text-sm font-extrabold text-teal-700">
                            @yorum.KullaniciBasHarfi
                        </div>

                        <div class="min-w-0 flex-1">
                            <div class="flex flex-wrap items-start justify-between gap-2">
                                <div>
                                    <div class="font-bold text-slate-800">@yorum.KullaniciAdi</div>
                                    <div class="mt-0.5 text-xs font-medium text-slate-400">
                                        @yorum.OlusturulmaTarihi.ToString("dd MMM yyyy · HH:mm")
                                        @if (yorum.DuzenlenmeTarihi.HasValue)
                                        {
                                            <span> · düzenlendi</span>
                                        }
                                    </div>
                                </div>

                                @if (yorum.SilinebilirMi)
                                {
                                    <form asp-controller="Gorev"
                                          asp-action="YorumSil"
                                          asp-route-id="@yorum.Id"
                                          method="post"
                                          data-confirm="Bu yorumu kaldırmak istediğinize emin misiniz?" data-confirm-title="Yorumu kaldır" data-confirm-action="Yorumu kaldır" data-confirm-tone="danger">
                                        <button type="submit"
                                                class="inline-flex h-9 w-9 items-center justify-center rounded-xl text-slate-400 transition hover:bg-red-50 hover:text-red-600"
                                                aria-label="Yorumu kaldır"
                                                title="Yorumu kaldır">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3" />
                                            </svg>
                                        </button>
                                    </form>
                                }
                            </div>

                            <div class="mt-3 whitespace-pre-wrap break-words text-sm leading-6 text-slate-600">@yorum.Icerik</div>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>
