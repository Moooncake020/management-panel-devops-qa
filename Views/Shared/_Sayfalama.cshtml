@using Microsoft.AspNetCore.Routing
@model SayfalamaViewModel

@if (Model.ToplamKayit > 0)
{
    var mevcutSorgu = new RouteValueDictionary();

    foreach (var anahtar in Context.Request.Query.Keys)
    {
        if (!string.Equals(anahtar, "sayfa", StringComparison.OrdinalIgnoreCase))
        {
            mevcutSorgu[anahtar] = Context.Request.Query[anahtar].ToString();
        }
    }

    string SayfaAdresi(int sayfa)
    {
        var degerler = new RouteValueDictionary(mevcutSorgu)
        {
            ["sayfa"] = sayfa
        };

        return Url.Action(Model.Action, Model.Controller, degerler) ?? "#";
    }

    var pencereBaslangici = Math.Max(1, Model.Sayfa - 2);
    var pencereBitisi = Math.Min(Model.ToplamSayfa, Model.Sayfa + 2);

    <nav class="mt-6 flex flex-col gap-4 border-t border-slate-200 pt-5 sm:flex-row sm:items-center sm:justify-between"
         aria-label="Sayfalama">
        <p class="text-sm text-slate-500" aria-live="polite">
            <span class="font-bold text-slate-700">@(Model.BaslangicKaydi)-@(Model.BitisKaydi)</span>
            arası gösteriliyor; toplam
            <span class="font-bold text-slate-700">@Model.ToplamKayit</span> kayıt.
        </p>

        <div class="flex flex-wrap items-center gap-2">
            @if (Model.OncekiVar)
            {
                <a href="@SayfaAdresi(Model.Sayfa - 1)"
                   rel="prev"
                   class="inline-flex h-10 items-center justify-center gap-1 rounded-xl border border-slate-200 bg-white px-3 text-sm font-bold text-slate-600 transition hover:border-teal-300 hover:text-teal-700">
                    <span aria-hidden="true">←</span>
                    Önceki
                </a>
            }
            else
            {
                <span class="inline-flex h-10 cursor-not-allowed items-center justify-center gap-1 rounded-xl border border-slate-100 bg-slate-50 px-3 text-sm font-bold text-slate-300" aria-disabled="true">
                    <span aria-hidden="true">←</span>
                    Önceki
                </span>
            }

            @if (pencereBaslangici > 1)
            {
                <a href="@SayfaAdresi(1)" class="pagination-number">1</a>
                @if (pencereBaslangici > 2)
                {
                    <span class="px-1 text-slate-400" aria-hidden="true">…</span>
                }
            }

            @for (var sayfa = pencereBaslangici; sayfa <= pencereBitisi; sayfa++)
            {
                if (sayfa == Model.Sayfa)
                {
                    <span class="pagination-number is-current" aria-current="page">@sayfa</span>
                }
                else
                {
                    <a href="@SayfaAdresi(sayfa)" class="pagination-number" aria-label="@(sayfa). sayfaya git">@sayfa</a>
                }
            }

            @if (pencereBitisi < Model.ToplamSayfa)
            {
                @if (pencereBitisi < Model.ToplamSayfa - 1)
                {
                    <span class="px-1 text-slate-400" aria-hidden="true">…</span>
                }
                <a href="@SayfaAdresi(Model.ToplamSayfa)" class="pagination-number">@Model.ToplamSayfa</a>
            }

            @if (Model.SonrakiVar)
            {
                <a href="@SayfaAdresi(Model.Sayfa + 1)"
                   rel="next"
                   class="inline-flex h-10 items-center justify-center gap-1 rounded-xl border border-slate-200 bg-white px-3 text-sm font-bold text-slate-600 transition hover:border-teal-300 hover:text-teal-700">
                    Sonraki
                    <span aria-hidden="true">→</span>
                </a>
            }
            else
            {
                <span class="inline-flex h-10 cursor-not-allowed items-center justify-center gap-1 rounded-xl border border-slate-100 bg-slate-50 px-3 text-sm font-bold text-slate-300" aria-disabled="true">
                    Sonraki
                    <span aria-hidden="true">→</span>
                </span>
            }
        </div>
    </nav>
}
