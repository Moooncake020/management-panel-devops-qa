@model BildirimMenuViewModel

<details class="notification-menu relative">
    <summary class="relative inline-flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-2xl border border-slate-200 bg-white text-slate-600 transition hover:border-teal-200 hover:bg-teal-50 hover:text-teal-700"
             aria-label="Bildirimleri aç"
             title="Bildirimler">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0a3 3 0 11-6 0h6z" />
        </svg>

        @if (Model.OkunmamisSayisi > 0)
        {
            <span class="absolute -right-1 -top-1 inline-flex min-h-5 min-w-5 items-center justify-center rounded-full bg-red-500 px-1 text-xs font-extrabold leading-none text-white ring-2 ring-white">
                @(Model.OkunmamisSayisi > 99 ? "99+" : Model.OkunmamisSayisi)
            </span>
        }
    </summary>

    <div class="notification-menu__panel absolute right-0 top-[calc(100%+0.65rem)] z-50 w-[min(92vw,25rem)] overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-2xl shadow-slate-900/15">
        <div class="flex items-center justify-between border-b border-slate-100 px-5 py-4">
            <div>
                <h2 class="font-extrabold text-slate-800">Bildirimler</h2>
                <p class="text-xs text-slate-500">
                    @(Model.OkunmamisSayisi > 0 ? $"{Model.OkunmamisSayisi} okunmamış bildirim" : "Yeni bildirim yok")
                </p>
            </div>

            @if (Model.OkunmamisSayisi > 0)
            {
                <form asp-controller="Bildirim" asp-action="TumunuOkunduYap" method="post">
                    <input type="hidden" name="geriDonus" value="@(Context.Request.Path.ToString() + Context.Request.QueryString.ToString())" />
                    <button type="submit" class="text-xs font-bold text-teal-700 transition hover:text-teal-900">
                        Tümünü oku
                    </button>
                </form>
            }
        </div>

        <div class="max-h-[25rem] overflow-y-auto">
            @if (!Model.SonBildirimler.Any())
            {
                <div class="px-6 py-10 text-center">
                    <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-2xl bg-slate-100 text-slate-400">
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0a3 3 0 11-6 0h6z" />
                        </svg>
                    </div>
                    <p class="mt-3 text-sm font-semibold text-slate-600">Henüz bildirim bulunmuyor.</p>
                </div>
            }
            else
            {
                @foreach (var bildirim in Model.SonBildirimler)
                {
                    var renkSinifi = bildirim.RenkKodu switch
                    {
                        "teal" => "bg-teal-50 text-teal-700",
                        "amber" => "bg-amber-50 text-amber-700",
                        "blue" => "bg-blue-50 text-blue-700",
                        "indigo" => "bg-indigo-50 text-indigo-700",
                        "red" => "bg-red-50 text-red-700",
                        "purple" => "bg-purple-50 text-purple-700",
                        _ => "bg-slate-100 text-slate-600"
                    };

                    <form asp-controller="Bildirim" asp-action="Oku" method="post" class="border-b border-slate-100 last:border-0">
                        <input type="hidden" name="id" value="@bildirim.Id" />
                        <input type="hidden" name="hedef" value="@bildirim.Link" />
                        <button type="submit" class="flex w-full items-start gap-3 px-5 py-4 text-left transition hover:bg-slate-50 @(!bildirim.OkunduMu ? "bg-teal-50/30" : "")">
                            <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl @renkSinifi">
                                @if (bildirim.IkonKodu == "yorum")
                                {
                                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h8m-8 4h5m8-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                }
                                else if (bildirim.IkonKodu == "takvim")
                                {
                                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3M5 11h14M5 5h14a2 2 0 012 2v12a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2z" /></svg>
                                }
                                else if (bildirim.IkonKodu == "uyari")
                                {
                                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" /></svg>
                                }
                                else if (bildirim.IkonKodu == "devret")
                                {
                                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4M16 17H4m0 0l4 4m-4-4l4-4" /></svg>
                                }
                                else
                                {
                                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
                                }
                            </span>

                            <span class="min-w-0 flex-1">
                                <span class="flex items-start justify-between gap-2">
                                    <span class="truncate text-sm font-extrabold text-slate-800">@bildirim.Baslik</span>
                                    @if (!bildirim.OkunduMu)
                                    {
                                        <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-teal-500" aria-label="Okunmamış"></span>
                                    }
                                </span>
                                <span class="mt-1 block line-clamp-2 text-xs leading-5 text-slate-500">@bildirim.Mesaj</span>
                                <span class="mt-1 block text-xs font-semibold text-slate-400">@bildirim.GecenSureMetni</span>
                            </span>
                        </button>
                    </form>
                }
            }
        </div>

        <a asp-controller="Bildirim" asp-action="Index" class="flex items-center justify-center gap-2 border-t border-slate-100 px-5 py-3.5 text-sm font-bold text-teal-700 transition hover:bg-teal-50">
            Tüm bildirimleri görüntüle
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
    </div>
</details>
