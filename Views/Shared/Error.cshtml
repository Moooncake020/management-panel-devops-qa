@model ErrorViewModel
@{
    ViewData["Title"] = Model.Baslik;
    Layout = User.Identity?.IsAuthenticated == true
        ? "_Layout"
        : "_PublicLayout";
}

<div class="mx-auto flex min-h-[68vh] max-w-3xl items-center justify-center px-4 py-12">
    <section class="w-full rounded-[2rem] border border-slate-200 bg-white p-7 text-center shadow-sm sm:p-10" role="alert">
        <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-2xl @(Model.StatusCode == 404 ? "bg-amber-50 text-amber-600" : "bg-red-50 text-red-600")">
            <span class="text-2xl font-black" aria-hidden="true">@Model.StatusCode</span>
        </div>
        <p class="mt-6 text-xs font-bold uppercase tracking-[0.22em] text-slate-400">Yönetim Paneli</p>
        <h1 class="mt-2 text-2xl font-extrabold text-slate-800 sm:text-3xl">@Model.Baslik</h1>
        <p class="mx-auto mt-3 max-w-xl text-sm leading-6 text-slate-500">@Model.Mesaj</p>

        @if (Model.ShowRequestId)
        {
            <div class="mx-auto mt-5 max-w-lg rounded-2xl bg-slate-50 px-4 py-3 text-left text-xs text-slate-500">
                <span class="font-bold text-slate-700">İstek kodu:</span>
                <code class="break-all">@Model.RequestId</code>
            </div>
        }

        <div class="mt-7 flex flex-col justify-center gap-3 sm:flex-row">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Home" asp-action="Index" class="app-button app-button--primary app-button--lg">Ana sayfaya dön</a>
            }
            else
            {
                <a asp-controller="Auth" asp-action="Login" class="app-button app-button--primary app-button--lg">Giriş sayfasına dön</a>
            }
            <button type="button" data-history-back class="app-button app-button--secondary app-button--lg">Önceki sayfaya dön</button>
        </div>
    </section>
</div>
