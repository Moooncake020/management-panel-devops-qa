@model LoginViewModel
@inject IWebHostEnvironment Environment

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0f172a" />
    <meta name="color-scheme" content="light" />
    <title>Giriş Yap - Yönetim Paneli</title>
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="min-h-screen overflow-x-hidden bg-slate-950 font-sans tracking-wide">
    <div class="fixed inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(20,184,166,0.25),_transparent_35%),radial-gradient(circle_at_bottom_right,_rgba(59,130,246,0.20),_transparent_35%)]"></div>
    <div class="fixed -right-24 -top-24 h-72 w-72 rounded-full bg-teal-500/10 blur-3xl"></div>
    <div class="fixed -bottom-24 -left-24 h-72 w-72 rounded-full bg-blue-500/10 blur-3xl"></div>

    <main class="relative flex min-h-screen items-center justify-center px-4 py-8 sm:px-6">
        <div class="grid w-full max-w-6xl grid-cols-1 overflow-hidden rounded-[2rem] border border-white/20 bg-white/95 shadow-2xl backdrop-blur-xl lg:grid-cols-2">

            <section class="relative hidden flex-col justify-between overflow-hidden bg-slate-900 p-10 text-white lg:flex">
                <div class="absolute inset-0 opacity-10" aria-hidden="true">
                    <div class="absolute left-10 top-10 h-32 w-32 rounded-full border border-white"></div>
                    <div class="absolute bottom-10 right-10 h-48 w-48 rounded-full border border-white"></div>
                    <div class="absolute left-1/2 top-1/2 h-24 w-24 rotate-45 rounded-2xl border border-white"></div>
                </div>

                <div class="relative">
                    <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-teal-500 shadow-lg shadow-teal-500/30">
                        <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                    </div>

                    <h1 class="mb-4 text-4xl font-extrabold leading-tight">
                        Yönetim Paneli<br />
                        <span class="text-teal-400">Görev ve Ekip Kontrolü</span>
                    </h1>

                    <p class="max-w-md text-sm leading-6 text-slate-300">
                        Hiyerarşik görev atama, kullanıcı yönetimi, görev devretme ve durum akışı tek panelden takip edilir.
                    </p>
                </div>

                <div class="relative grid grid-cols-3 gap-3">
                    <div class="rounded-2xl border border-white/10 bg-white/10 p-4">
                        <svg class="mb-2 h-6 w-6 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87M15 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                        <div class="text-xs text-slate-300">Ekip</div>
                    </div>
                    <div class="rounded-2xl border border-white/10 bg-white/10 p-4">
                        <svg class="mb-2 h-6 w-6 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                        <div class="text-xs text-slate-300">Görev</div>
                    </div>
                    <div class="rounded-2xl border border-white/10 bg-white/10 p-4">
                        <svg class="mb-2 h-6 w-6 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4M16 17H4m0 0l4 4m-4-4l4-4" /></svg>
                        <div class="text-xs text-slate-300">Devret</div>
                    </div>
                </div>
            </section>

            <section class="p-7 sm:p-10 lg:p-12">
                <div class="mb-8 text-center">
                    <div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-2xl bg-teal-500 text-white shadow-lg shadow-teal-500/30 lg:hidden">
                        <svg class="h-9 w-9" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                    </div>
                    <h1 class="mb-2 text-3xl font-extrabold text-slate-800">Panel <span class="text-teal-600">Girişi</span></h1>
                    <p class="text-sm text-slate-500">Devam etmek için hesabınızla giriş yapın.</p>
                </div>

                @await Html.PartialAsync("_FlashMessages")

                <form asp-controller="Auth"
                      asp-action="Login"
                      method="post"
                      id="loginForm"
                      class="space-y-5"
                      novalidate>
                    <input asp-for="ReturnUrl" type="hidden" />

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly"
                             class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-semibold text-red-700"
                             role="alert">
                        </div>
                    }

                    <div>
                        <label asp-for="Email" class="mb-2 flex items-center gap-2 text-sm font-bold text-slate-700">
                            <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                            E-posta
                        </label>
                        <div class="relative">
                            <span class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12H8m8 0a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                            </span>
                            <input asp-for="Email"
                                   autocomplete="username"
                                   placeholder="ornek@sirket.com"
                                   class="w-full rounded-xl border border-slate-200 bg-slate-50 py-3.5 pl-12 pr-4 text-slate-700 transition-colors focus:border-teal-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500" />
                        </div>
                        <span asp-validation-for="Email" class="mt-1.5 block text-xs font-semibold text-red-600"></span>
                    </div>

                    <div>
                        <label asp-for="Password" class="mb-2 flex items-center gap-2 text-sm font-bold text-slate-700">
                            <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4" /></svg>
                            Şifre
                        </label>
                        <div class="relative">
                            <span class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" /></svg>
                            </span>
                            <input asp-for="Password"
                                   id="loginPassword"
                                   autocomplete="current-password"
                                   placeholder="Şifrenizi girin"
                                   class="w-full rounded-xl border border-slate-200 bg-slate-50 py-3.5 pl-12 pr-12 text-slate-700 transition-colors focus:border-teal-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500" />
                            <button type="button"
                                    id="toggleLoginPassword"
                                    class="absolute right-2 top-1/2 inline-flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-xl text-slate-400 transition hover:bg-white hover:text-slate-700"
                                    aria-label="Şifreyi göster"
                                    aria-pressed="false">
                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zm6 0c-1.5 4-4.5 6-9 6s-7.5-2-9-6c1.5-4 4.5-6 9-6s7.5 2 9 6z" /></svg>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="mt-1.5 block text-xs font-semibold text-red-600"></span>
                        <div id="capsLockWarning" class="mt-2 hidden text-xs font-semibold text-amber-700" role="status">Caps Lock açık.</div>
                    </div>

                    <label class="flex cursor-pointer items-center gap-3 text-sm font-semibold text-slate-600">
                        <input asp-for="BeniHatirla"
                               class="h-4 w-4 rounded border-slate-300 text-teal-600 focus:ring-teal-500" />
                        <span>Bu cihazda oturumu açık tut</span>
                    </label>

                    <button type="submit"
                            id="loginSubmitButton"
                            class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-teal-500 to-teal-600 px-4 py-3.5 font-bold text-white shadow-md transition-all duration-300 hover:from-teal-600 hover:to-teal-700 hover:shadow-lg disabled:cursor-not-allowed disabled:opacity-70">
                        <svg id="loginButtonIcon" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" /></svg>
                        <svg id="loginSpinner" class="hidden h-5 w-5 animate-spin" fill="none" viewBox="0 0 24 24" aria-hidden="true"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path></svg>
                        <span id="loginButtonText">Giriş Yap</span>
                    </button>
                </form>

                @if (Environment.IsDevelopment())
                {
                    <aside class="mt-8 rounded-2xl border border-slate-200 bg-slate-50 p-4">
                        <div class="mb-3 flex items-center gap-2 text-xs font-bold uppercase text-slate-500">
                            <svg class="h-4 w-4 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                            Development test hesapları
                        </div>
                        <div class="grid grid-cols-1 gap-2 text-xs text-slate-600 sm:grid-cols-2">
                            <div class="rounded-xl border border-slate-100 bg-white px-3 py-2"><strong>admin@test.com</strong> / 123456</div>
                            <div class="rounded-xl border border-slate-100 bg-white px-3 py-2"><strong>mehmet@test.com</strong> / 123456</div>
                            <div class="rounded-xl border border-slate-100 bg-white px-3 py-2"><strong>kemal@test.com</strong> / 123456</div>
                            <div class="rounded-xl border border-slate-100 bg-white px-3 py-2"><strong>ayse@test.com</strong> / 123456</div>
                        </div>
                        <p class="mt-3 text-xs leading-5 text-slate-400">Bu alan yalnızca Development ortamında görünür. Üretimde test hesapları oluşturulmaz.</p>
                    </aside>
                }
            </section>
        </div>
    </main>

    <script src="~/js/site.js" asp-append-version="true" defer></script>
    <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true" defer></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js" asp-append-version="true" defer></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js" asp-append-version="true" defer></script>
    <script src="~/js/pages/auth-login.js" asp-append-version="true" defer></script>
</body>
</html>
