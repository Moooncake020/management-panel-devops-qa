@model SifreDegistirViewModel

@{
    ViewData["Title"] = "Şifre Değiştir";
}

<div class="mx-auto max-w-3xl space-y-6">
    <div>
        <a asp-controller="Profil"
           asp-action="Index"
           class="inline-flex items-center gap-2 text-sm font-bold text-teal-700 transition hover:text-teal-900">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
            Profilime dön
        </a>
    </div>

    <section class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm">
        <div class="bg-gradient-to-r from-slate-900 via-slate-800 to-teal-900 px-6 py-7 text-white sm:px-8">
            <div class="flex items-center gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-white/10 text-teal-300 ring-1 ring-white/10">
                    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4" /></svg>
                </div>
                <div>
                    <div class="text-xs font-bold uppercase tracking-[0.2em] text-teal-300">Hesap Güvenliği</div>
                    <h1 class="mt-1 text-2xl font-black sm:text-3xl">Şifrenizi değiştirin</h1>
                    <p class="mt-1 text-sm leading-6 text-slate-300">İşlem tamamlandığında bütün eski oturumlar geçersiz olur ve tekrar giriş yapmanız gerekir.</p>
                </div>
            </div>
        </div>

        <form asp-controller="Auth"
              asp-action="SifreDegistir"
              method="post"
              id="changePasswordForm"
              class="space-y-6 p-6 sm:p-8">

            <div asp-validation-summary="ModelOnly"
                 class="validation-summary-errors rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-semibold text-red-700"
                 role="alert">
            </div>

            <div>
                <label asp-for="MevcutSifre" class="mb-2 block text-sm font-bold text-slate-700"></label>
                <div class="relative">
                    <input asp-for="MevcutSifre"
                           id="currentPassword"
                           autocomplete="current-password"
                           class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 pr-12 text-slate-700 focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500" />
                    <button type="button"
                            data-password-toggle="currentPassword"
                            class="absolute right-2 top-1/2 inline-flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-xl text-slate-400 transition hover:bg-white hover:text-slate-700"
                            aria-label="Mevcut şifreyi göster">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zm6 0c-1.5 4-4.5 6-9 6s-7.5-2-9-6c1.5-4 4.5-6 9-6s7.5 2 9 6z" /></svg>
                    </button>
                </div>
                <span asp-validation-for="MevcutSifre" class="mt-1.5 block text-xs font-semibold text-red-600"></span>
            </div>

            <div class="grid gap-5 md:grid-cols-2">
                <div>
                    <label asp-for="YeniSifre" class="mb-2 block text-sm font-bold text-slate-700"></label>
                    <div class="relative">
                        <input asp-for="YeniSifre"
                               id="newPassword"
                               autocomplete="new-password"
                               class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 pr-12 text-slate-700 focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500" />
                        <button type="button"
                                data-password-toggle="newPassword"
                                class="absolute right-2 top-1/2 inline-flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-xl text-slate-400 transition hover:bg-white hover:text-slate-700"
                                aria-label="Yeni şifreyi göster">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zm6 0c-1.5 4-4.5 6-9 6s-7.5-2-9-6c1.5-4 4.5-6 9-6s7.5 2 9 6z" /></svg>
                        </button>
                    </div>
                    <span asp-validation-for="YeniSifre" class="mt-1.5 block text-xs font-semibold text-red-600"></span>
                </div>

                <div>
                    <label asp-for="YeniSifreTekrar" class="mb-2 block text-sm font-bold text-slate-700"></label>
                    <div class="relative">
                        <input asp-for="YeniSifreTekrar"
                               id="newPasswordRepeat"
                               autocomplete="new-password"
                               class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 pr-12 text-slate-700 focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500" />
                        <button type="button"
                                data-password-toggle="newPasswordRepeat"
                                class="absolute right-2 top-1/2 inline-flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-xl text-slate-400 transition hover:bg-white hover:text-slate-700"
                                aria-label="Yeni şifre tekrarını göster">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zm6 0c-1.5 4-4.5 6-9 6s-7.5-2-9-6c1.5-4 4.5-6 9-6s7.5 2 9 6z" /></svg>
                        </button>
                    </div>
                    <span asp-validation-for="YeniSifreTekrar" class="mt-1.5 block text-xs font-semibold text-red-600"></span>
                </div>
            </div>

            <div class="rounded-2xl border border-blue-100 bg-blue-50 p-4 text-sm text-blue-800">
                <div class="font-extrabold">Yeni şifre kuralları</div>
                <ul class="mt-2 space-y-1 text-xs leading-5 text-blue-700">
                    <li>En az 8, en fazla 100 karakter</li>
                    <li>En az bir büyük harf, bir küçük harf ve bir rakam</li>
                    <li>Boşluk içeremez ve mevcut şifreyle aynı olamaz</li>
                </ul>
            </div>

            <div class="flex flex-col-reverse gap-3 border-t border-slate-200 pt-6 sm:flex-row sm:justify-end">
                <a asp-controller="Profil"
                   asp-action="Index"
                   class="inline-flex h-11 items-center justify-center rounded-2xl border border-slate-200 px-5 text-sm font-bold text-slate-600 transition hover:bg-slate-50">
                    Vazgeç
                </a>
                <button type="submit"
                        id="changePasswordSubmit"
                        class="inline-flex h-11 items-center justify-center gap-2 rounded-2xl bg-teal-600 px-6 text-sm font-bold text-white transition hover:bg-teal-700 disabled:cursor-not-allowed disabled:opacity-70">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                    <span>Şifreyi Değiştir</span>
                </button>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/auth-sifre-degistir.js" asp-append-version="true" defer></script>
}
