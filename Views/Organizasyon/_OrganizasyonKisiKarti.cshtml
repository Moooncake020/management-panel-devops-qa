@model OrganizasyonDugumViewModel

<article class="org-person-card group rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-teal-200 hover:shadow-md">
    <div class="flex items-start gap-3">
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-teal-100 to-cyan-50 text-sm font-extrabold text-teal-700 ring-1 ring-teal-100">
            @Model.BasHarfler
        </div>

        <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-start justify-between gap-2">
                <div class="min-w-0">
                    <h3 class="truncate text-base font-extrabold text-slate-800" title="@Model.TamAd">
                        <a asp-controller="Profil" asp-action="Index" asp-route-id="@Model.Id" class="transition hover:text-teal-700">@Model.TamAd</a>
                    </h3>
                    <p class="mt-0.5 truncate text-sm font-medium text-slate-500" title="@Model.UnvanAdi">
                        @Model.UnvanAdi
                    </p>
                </div>

                @if (Model.SistemRolu == "Admin")
                {
                    <span class="inline-flex items-center gap-1 rounded-full bg-indigo-50 px-2.5 py-1 text-xs font-bold uppercase tracking-wider text-indigo-600">
                        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                        Admin
                    </span>
                }
            </div>

            <div class="mt-3 flex flex-wrap gap-2">
                <span class="inline-flex items-center gap-1 rounded-full bg-teal-50 px-2.5 py-1 text-xs font-bold text-teal-700">
                    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7h18M5 7v12h14V7M9 7V5a2 2 0 012-2h2a2 2 0 012 2v2" />
                    </svg>
                    @Model.DepartmanAdi
                </span>

                <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-1 text-xs font-bold text-slate-600">
                    @Model.OrganizasyonRoluAdi
                </span>

                <span class="inline-flex items-center rounded-full bg-blue-50 px-2.5 py-1 text-xs font-bold text-blue-600">
                    @Model.KidemAdi
                </span>
            </div>

            <div class="mt-3 flex flex-wrap items-center justify-between gap-2 border-t border-slate-100 pt-3 text-xs text-slate-500">
                <span class="min-w-0 truncate" title="@Model.Email">@Model.Email</span>
                <a asp-controller="Profil" asp-action="Index" asp-route-id="@Model.Id" class="inline-flex items-center gap-1 font-bold text-teal-700 transition hover:text-teal-900">
                    Profili aç
                    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </a>

                @if (Model.DogrudanAstSayisi > 0)
                {
                    <span class="inline-flex shrink-0 items-center gap-1 font-bold text-slate-600">
                        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87M15 7a4 4 0 11-8 0 4 4 0 018 0z" />
                        </svg>
                        @Model.DogrudanAstSayisi doğrudan ast
                    </span>
                }
            </div>
        </div>
    </div>
</article>
