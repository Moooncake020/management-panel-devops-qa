@model OrganizasyonIndexViewModel

@{
    ViewData["Title"] = "Organizasyon Şeması";
}

<div class="space-y-6">
    <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <div class="relative p-5 lg:p-7">
            <div class="pointer-events-none absolute -right-16 -top-20 h-52 w-52 rounded-full bg-teal-100/50 blur-3xl"></div>
            <div class="relative flex flex-col gap-5 xl:flex-row xl:items-start xl:justify-between">
                <div class="max-w-3xl">
                    <div class="mb-3 inline-flex items-center gap-2 rounded-full bg-teal-50 px-3 py-1 text-xs font-bold uppercase tracking-wider text-teal-700">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h6m4 0h6M4 18h4m4 0h8" />
                        </svg>
                        Hiyerarşik görünüm
                    </div>
                    <h1 class="text-2xl font-extrabold tracking-tight text-slate-900 lg:text-3xl">
                        Organizasyon yapısını tek ekranda inceleyin
                    </h1>
                    <p class="mt-2 text-sm leading-6 text-slate-500 lg:text-[15px]">
                        Yöneticiler ve bağlı çalışanlar gerçek kullanıcı ilişkilerinden oluşturulur.
                        Arama ve departman filtresi ile büyük ekiplerde ilgili kişiye hızlıca ulaşabilirsiniz.
                    </p>
                </div>

                @if (Model.AdminMi)
                {
                    <a asp-controller="Organizasyon"
                       asp-action="Yonetim"
                       class="inline-flex shrink-0 items-center justify-center gap-2 rounded-2xl bg-slate-900 px-5 py-3 text-sm font-bold text-white shadow-sm transition hover:bg-slate-800">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 16v-2m8-6h-2M6 12H4m13.657-5.657l-1.414 1.414M7.757 16.243l-1.414 1.414m11.314 0l-1.414-1.414M7.757 7.757L6.343 6.343M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        Birimleri Yönet
                    </a>
                }
            </div>
        </div>
    </section>

    <section class="grid grid-cols-2 gap-3 lg:grid-cols-4">
        <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
            <div class="text-xs font-bold uppercase tracking-widest text-slate-400">Aktif çalışan</div>
            <div class="mt-2 text-3xl font-extrabold text-slate-800">@Model.AktifKullaniciSayisi</div>
        </div>
        <div class="rounded-2xl border border-teal-100 bg-teal-50 p-4">
            <div class="text-xs font-bold uppercase tracking-widest text-teal-600">Yönetici</div>
            <div class="mt-2 text-3xl font-extrabold text-teal-700">@Model.YoneticiSayisi</div>
        </div>
        <div class="rounded-2xl border border-indigo-100 bg-indigo-50 p-4">
            <div class="text-xs font-bold uppercase tracking-widest text-indigo-600">Aktif departman</div>
            <div class="mt-2 text-3xl font-extrabold text-indigo-700">@Model.DepartmanSayisi</div>
        </div>
        <div class="rounded-2xl border border-blue-100 bg-blue-50 p-4">
            <div class="text-xs font-bold uppercase tracking-widest text-blue-600">Hiyerarşi derinliği</div>
            <div class="mt-2 text-3xl font-extrabold text-blue-700">@Model.EnDerinSeviye</div>
        </div>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm lg:p-6">
        <div class="mb-5 flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between">
            <div class="grid w-full grid-cols-1 gap-3 md:grid-cols-2 xl:max-w-3xl">
                <div>
                    <label for="orgSearch" class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-500">
                        Kişi veya birim ara
                    </label>
                    <div class="relative">
                        <svg class="absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M10.5 18a7.5 7.5 0 110-15 7.5 7.5 0 010 15z" />
                        </svg>
                        <input id="orgSearch"
                               type="search"
                               placeholder="Ad, e-posta, unvan..."
                               class="w-full rounded-2xl border border-slate-200 bg-slate-50 py-3 pl-11 pr-4 text-sm text-slate-700 focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500" />
                    </div>
                </div>

                <div>
                    <label for="orgDepartmentFilter" class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-500">
                        Departman
                    </label>
                    <select id="orgDepartmentFilter"
                            class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500">
                        <option value="">Tüm departmanlar</option>
                        @foreach (var departman in Model.Departmanlar)
                        {
                            <option value="@departman">@departman</option>
                        }
                    </select>
                </div>
            </div>

            <div class="flex flex-wrap gap-2">
                <button id="expandOrgTree"
                        type="button"
                        class="inline-flex items-center gap-2 rounded-xl bg-teal-50 px-4 py-2.5 text-sm font-bold text-teal-700 transition hover:bg-teal-100">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                    Tümünü Aç
                </button>
                <button id="collapseOrgTree"
                        type="button"
                        class="inline-flex items-center gap-2 rounded-xl bg-slate-100 px-4 py-2.5 text-sm font-bold text-slate-600 transition hover:bg-slate-200">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                    </svg>
                    Tümünü Kapat
                </button>
            </div>
        </div>

        @if (!Model.KokDugumler.Any())
        {
            <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 px-6 py-16 text-center">
                <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-white text-slate-300 shadow-sm">
                    <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87M15 7a4 4 0 11-8 0 4 4 0 018 0z" />
                    </svg>
                </div>
                <p class="mt-4 font-bold text-slate-700">Organizasyon şemasında gösterilecek aktif kullanıcı yok.</p>
            </div>
        }
        else
        {
            <div id="orgTree" class="org-tree overflow-x-auto pb-3">
                <ul class="org-root-list">
                    @foreach (var kokDugum in Model.KokDugumler)
                    {
                        <partial name="_OrganizasyonDugumu" model="kokDugum" />
                    }
                </ul>
            </div>

            <div id="orgNoResult" class="hidden rounded-2xl border border-dashed border-slate-300 bg-slate-50 px-6 py-12 text-center text-sm font-semibold text-slate-500">
                Arama ve filtre ölçütlerine uyan kişi bulunamadı.
            </div>
        }
    </section>
</div>

@section Scripts {
    <script src="~/js/pages/organizasyon-index.js" asp-append-version="true" defer></script>
}
